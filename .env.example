# =============================================================================
# LeaseAI — Variables d'environnement (exemple)
# Copier en .env.local et remplir. Ne jamais committer .env.local
# =============================================================================

APP_ENV=local

# Mobile (Expo)
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_APP_ENV=local
EXPO_PUBLIC_SUPABASE_URL=https://<project_ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon_key>
EXPO_PUBLIC_SENTRY_DSN=

# Web back-office (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_SUPABASE_URL=https://<project_ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon_key>
NEXT_PUBLIC_SENTRY_DSN=

# Backend
API_BASE_URL=http://localhost:8000
SUPABASE_JWKS_URL=https://<project_ref>.supabase.co/auth/v1/.well-known/jwks.json  # ECC P-256, algo ES256

# Supabase
DATABASE_URL=postgresql://postgres:<password>@db.<project_ref>.supabase.co:5432/postgres
SUPABASE_URL=https://<project_ref>.supabase.co
SUPABASE_PROJECT_REF=<project_ref>
SUPABASE_ANON_KEY=<anon_key>
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<key>
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>
SUPABASE_SECRET_KEY=sb_secret_<key>
SUPABASE_ACCESS_TOKEN=sbp_<token>  # supabase.com/dashboard/account/tokens

# Storage
OBJECT_STORAGE_BUCKET=lease-documents
OBJECT_STORAGE_URL=https://<project_ref>.supabase.co/storage/v1
SIGNED_URL_EXPIRY_SECONDS=300

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Anthropic
ANTHROPIC_API_KEY=
LLM_MODEL_EXTRACTION=claude-haiku-4-5-20251001
LLM_MODEL_ASSISTANT=claude-sonnet-4-6

# Pappers
PAPPERS_API_KEY=
PAPPERS_BASE_URL=https://api.pappers.fr/v2

# Yousign
YOUSIGN_API_KEY=
YOUSIGN_ENVIRONMENT=sandbox
YOUSIGN_WEBHOOK_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Resend
RESEND_API_KEY=re_
EMAIL_FROM=noreply@lease.ai

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=1.0

# Deploy CI/CD
EXPO_TOKEN=             # expo.dev > Account Settings > Access Tokens
RAILWAY_TOKEN=          # railway.com > Account > Tokens

# GitHub MCP
GITHUB_TOKEN=ghp_<token>

# Feature flags
FEATURE_FLAG_MOCK_SIREN=true
FEATURE_FLAG_MOCK_SIGNATURE=true
FEATURE_FLAG_MOCK_SEPA=true
FEATURE_FLAG_AI_ASSISTANT=true
FEATURE_FLAG_REFI_MULTI_FINANCIER=false
